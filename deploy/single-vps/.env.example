# Copy to `.env` and fill in. Never commit the real `.env`.
# Generate secrets with:  openssl rand -base64 32   (KYC_STORAGE_KEY needs 32 bytes)

# --- Public hostname --------------------------------------------------------
# DNS A record must point at this VPS; Caddy gets a Let's Encrypt cert for it.
KYC_DOMAIN=verify.example.com
ACME_EMAIL=ops@example.com

# --- Datastore passwords ----------------------------------------------------
POSTGRES_PASSWORD=change-me-strong-random
REDIS_PASSWORD=change-me-strong-random

# --- App secrets (CHANGE ALL) ----------------------------------------------
# Long-lived: rotating the salt invalidates every existing PII/identity hash.
KYC_PII_SALT=change-me-long-lived-random
# 32-byte base64 key for at-rest media encryption (openssl rand -base64 32).
KYC_STORAGE_KEY=change-me-base64-32-bytes
# Keys the P2P layer / staff present (X-API-Key / X-Admin-Key). Comma-separated.
KYC_P2P_API_KEYS=change-me-p2p-key
KYC_ADMIN_API_KEYS=change-me-admin-key
