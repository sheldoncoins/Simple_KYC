# Copy to .env and adjust. Never commit a real .env (see .gitignore).
# These are the only environment variables the app reads today.

# --- Database ---------------------------------------------------------------
# Postgres is the production/dev target (docker-compose provides one). Apply
# schema with `alembic upgrade head` before first use.
KYC_DATABASE_URL=postgresql+psycopg://kyc:kyc@localhost:5432/kyc
# Zero-config alternative (and what the test suite uses):
# KYC_DATABASE_URL=sqlite:///./kyc.db

# --- Signing key ------------------------------------------------------------
# Ed25519 private key (PEM) used to sign credentials. A dev key is generated
# here on first run. In production the key lives in a KMS/HSM (Phase 1) and this
# path is unused.
KYC_SIGNING_KEY_PATH=./signing_key.pem

# --- PII hashing salt -------------------------------------------------------
# Salt for HMAC-hashing PII (phone/email) and deriving identity handles.
# CHANGE THIS per deployment and source it from a secret manager. Rotating it
# invalidates existing hashes, so treat it as a long-lived deployment secret.
KYC_PII_SALT=dev-pii-salt-change-me

# --- Credential signer ------------------------------------------------------
# local = in-process Ed25519 key (dev/self-hosted). kms = KMS/HSM-backed signer
# (production seam; not implemented in the reference build).
KYC_SIGNER=local

# --- P2P client authentication ----------------------------------------------
# Comma-separated API keys the P2P layer presents via the X-API-Key header to
# call the authenticated endpoints (credential verify/revoke, limit debit/read).
# Generate strong random values per client and rotate by editing this list.
KYC_P2P_API_KEYS=replace-with-a-strong-random-key

# --- Staff authentication ---------------------------------------------------
# Comma-separated keys for staff/admin endpoints (review queue, audit log,
# metrics), presented via the X-Admin-Key header. Keep separate from P2P keys.
KYC_ADMIN_API_KEYS=replace-with-a-strong-random-admin-key

# --- Rate limiting (per client IP, per minute) ------------------------------
KYC_RATELIMIT_ONBOARD_PER_MIN=120
KYC_RATELIMIT_BIOMETRIC_PER_MIN=120

# --- Media storage ----------------------------------------------------------
# local = AES-256-GCM encrypted blobs on disk (dev). s3 = S3-compatible storage
# with server-side encryption (set KYC_S3_BUCKET, AWS_* creds, optional
# KYC_S3_ENDPOINT_URL for MinIO; requires `pip install boto3`).
KYC_STORAGE_BACKEND=local
KYC_STORAGE_DIR=./media_store
# 32-byte base64 key for local encrypted storage. CHANGE per deployment and
# source from a secret manager. If unset, a dev key is generated under the dir.
# KYC_STORAGE_KEY=
# KYC_S3_BUCKET=
# KYC_S3_ENDPOINT_URL=

# Retention for raw uploaded media (seconds). Only derived templates persist
# long-term; the purge job (python -m app.jobs.purge_media) deletes the rest.
KYC_MEDIA_RETENTION_SECONDS=86400

# --- MRZ reader -------------------------------------------------------------
# text = read MRZ lines from an uploaded text blob (dev/test). ocr = real OCR
# over the image via PassportEye/Tesseract -- install `requirements-ocr.txt`
# plus the tesseract binary (brew/apt) to use it.
KYC_MRZ_READER=text

# --- 1:N dedup search backend -----------------------------------------------
# linear = cosine scan over IdentityRecord (default). pgvector = ANN via the
# Postgres pgvector extension (decision/thresholds identical, only faster).
KYC_DEDUP_BACKEND=linear
KYC_EMBEDDING_DIM=128

# --- Face matcher -----------------------------------------------------------
# mock = deterministic seeded embeddings (dev/test). insightface = self-hosted
# ArcFace (production; needs the model stack + real selfie/passport images).
KYC_FACE_MATCHER=mock

# --- Biometric task queue ---------------------------------------------------
# inline = run the decision in-request (default). arq = dispatch to the Redis
# worker (`arq app.worker.WorkerSettings`); the client then polls session status.
KYC_TASK_QUEUE=inline
KYC_REDIS_URL=redis://localhost:6379

# --- CORS -------------------------------------------------------------------
# Comma-separated origins allowed to call the API from a browser (the web/
# wizard). Lock this down in production.
KYC_CORS_ORIGINS=http://localhost:3000

# --- Tracing (OpenTelemetry, optional) --------------------------------------
# 1/true to enable; requires the opentelemetry-* packages (see app/tracing.py).
KYC_OTEL_ENABLED=0
KYC_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# --- Logging ----------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
KYC_LOG_LEVEL=INFO
# Renderer: console (human-readable, dev) | json (structured, prod)
KYC_LOG_FORMAT=console
